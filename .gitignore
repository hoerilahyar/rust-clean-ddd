```gitignore
#==================================================
# Rust
#==================================================

/target/
debug/
release/

# Generated by Cargo
Cargo.lock

# Jika project berupa aplikasi (binary), biasanya Cargo.lock
# justru DI-COMMIT. Hapus baris di atas apabila ingin
# menyimpan Cargo.lock ke repository.

#==================================================
# Environment
#==================================================

.env
.env.*
!.env.example

#==================================================
# Logs
#==================================================

logs/
*.log

#==================================================
# Uploads
#==================================================

uploads/

#==================================================
# Database
#==================================================

*.sqlite
*.sqlite3
*.db

#==================================================
# IDE
#==================================================

.vscode/
.idea/

*.iml

#==================================================
# OS
#==================================================

.DS_Store
Thumbs.db
desktop.ini

#==================================================
# Temporary
#==================================================

tmp/
temp/
.cache/

*.tmp
*.swp
*.swo

#==================================================
# Testing
#==================================================

coverage/
*.profraw
*.profdata

#==================================================
# Rust Analyzer
#==================================================

.rustc_info.json

#==================================================
# Build
#==================================================

dist/
build/

#==================================================
# Docker
#==================================================

docker-data/

#==================================================
# Backup
#==================================================

*.bak
*.old
*.orig

#==================================================
# Local Configuration
#==================================================

configs/local.toml
configs/development.local.toml

#==================================================
# Generated Documentation
#==================================================

docs/generated/

#==================================================
# Certificates
#==================================================

*.pem
*.key
*.crt
*.p12
*.pfx

#==================================================
# Secrets
#==================================================

secrets/
```
